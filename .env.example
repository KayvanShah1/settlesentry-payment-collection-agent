# SettleSentry environment template
# Copy this file to `.env` and edit values as needed.
#
# Deterministic mode does NOT require an OpenRouter API key.
# LLM modes (`llm-parser-workflow`, `llm-parser-responder-workflow`,
# `llm-autonomous-agent`) require OPENROUTER_API_KEY.

# ---------------------------------------------------------------------------
# Core project settings (advanced, optional)
# ---------------------------------------------------------------------------
# PROJECT_ROOT=C:\path\to\repo
# PROJECT_NAME=settlesentry
# VAR_DIR=var
# LOG_DIR=var\logs

# ---------------------------------------------------------------------------
# Logging (prefix: LOG_)
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_CONSOLE_ENABLED=true
# Optional explicit filename. If unset, defaults to "<project_name>.log".
# LOG_FILE_NAME=settlesentry.log
LOG_MAX_BYTES=2048000
LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# External payment API config (prefix: API_)
# ---------------------------------------------------------------------------
API_BASE_URL=https://se-payment-verification-api.service.external.usea2.aws.prodigaltech.com
API_TIMEOUT_SECONDS=30
API_MAX_RETRIES=2

# ---------------------------------------------------------------------------
# OpenRouter / LLM config (prefix: OPENROUTER_)
# ---------------------------------------------------------------------------
OPENROUTER_ENABLED=true
# Required only for LLM modes:
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIMEOUT_SECONDS=10
OPENROUTER_TEMPERATURE=0.0
OPENROUTER_MAX_TOKENS=300
OPENROUTER_RETRIES=1

# ---------------------------------------------------------------------------
# Agent policy controls (prefix: AGENT_POLICY_)
# ---------------------------------------------------------------------------
AGENT_POLICY_VERIFICATION_MAX_ATTEMPTS=3
AGENT_POLICY_PAYMENT_MAX_ATTEMPTS=3
AGENT_POLICY_ALLOW_PARTIAL_PAYMENTS=true
AGENT_POLICY_ALLOW_ZERO_BALANCE_PAYMENT=false
# Optional hard cap for payment amount. Leave commented to disable.
# AGENT_POLICY_MAX_PAYMENT_AMOUNT=50000

# ---------------------------------------------------------------------------
# Evaluator settings for scripts/evaluate_agent.py (prefix: EVAL_)
# ---------------------------------------------------------------------------
EVAL_REPORT_RETENTION=10
EVAL_LOCAL_REPEATS_DEFAULT=1
EVAL_LLM_REPEATS_DEFAULT=1
EVAL_SCENARIO_RETRIES_DEFAULT=1
EVAL_REPORT_WIDTH=160
